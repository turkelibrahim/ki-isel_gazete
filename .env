# Server
PORT=3000
APP_ORIGIN=http://localhost:3000
SESSION_SECRET=change-this-long-random-secret

# News providers
FREENEWSAPI_KEY=your_freenewsapi_key_here
NEWS_API_KEY=
GNEWS_API_KEY=
MEDIASTACK_API_KEY=your_mediastack_api_key_here

# RSS sources do not usually need API keys.
# Leave empty to use the built-in REGIONAL_SOURCE_CATALOG (multi-region RSS across 9 regions).
# Comma-separated URLs override the catalog entirely — use sparingly.
RSS_FEEDS=

# Regional fetch tuning
RSS_FETCH_CONCURRENCY=8
RSS_FETCH_TIMEOUT_MS=8000
RSS_CACHE_TTL_MS=300000

# Event providers
# Get a key from https://developer.ticketmaster.com/products-and-docs/apis/discovery-api/v2/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
EVENT_COUNTRY_CODE=TR
EVENT_CITY=Istanbul
EVENT_SIZE=18

# AI provider
# Gemini is currently wired in server.js.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Finance providers
# Harem Altin / AltinAPI: Dolar, Euro, sterlin ve altin fiyatlari icin oncelikli kaynak.
# Harem web sayfasi Cloudflare ile korunabildigi icin en stabil yol API key kullanmaktir.
HAREM_ALTIN_API_KEY=
HAREM_ALTIN_API_BASE_URL=https://altinapi.com/api/v1
# ─ TCMB today.xml (döviz kurları): Herkese açık, API key gerekmez.
# ─ metals.live (XAU/USD, XAG/USD): Herkese açık, API key gerekmez.
# ─ CoinGecko public (kripto): API key olmadan çalışır, rate limit uygulanır.
#   Pro API key ile rate limit artar — isteğe bağlı.
COINGECKO_API_KEY=
# ─ TCMB EVDS: Politika faizi (TP.DF.D03.A) ve makro seri verileri için.
#   Key sunucu tarafında .env içinde tutulur. Frontend'e kesinlikle açılmaz.
#   https://evds2.tcmb.gov.tr/ adresinden ücretsiz kayıt ile alınabilir.
EVDS_API_KEY=
# Backward-compatible legacy name:
TCMB_EVDS_API_KEY=
# ─ BIST gerçek zamanlı veri: Lisanslı veri sağlayıcı sözleşmesi gerektirir.
#   Sağlayıcı seçildikten sonra key buraya eklenir. Sahte değer gösterilmez.
BIST_PROVIDER_API_KEY=
BIST_PROVIDER_BASE_URL=
# ─ KAP bildirimleri: Lisans/sözleşme gerektirir. Sahte veri gösterilmez.
KAP_API_ENABLED=false
KAP_API_KEY=
KAP_API_BASE_URL=

# Source Follow Center
# YouTube RSS mode does not require a key. If API fallback is added in production, keep the key server-side only.
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here
SOURCE_FETCH_TIMEOUT_MS=6500
SOURCE_CACHE_TTL_MINUTES=15

# Python FastAPI crawler backend
# Example: postgresql+asyncpg://postgres:postgres@localhost:5432/smart_newspaper
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smart_newspaper

# Celery / Redis queue
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# DEDUPLICATION
# MinHash + LSH runs in-process and in the daily Celery task. Install backend/requirements.txt.

# NewsAPI provider pacing
NEWSAPI_RATE_LIMIT_SECONDS=36

# Module 3 personal newspaper / recommendation cache
PERSONAL_FEED_CACHE_TTL_SECONDS=300

# Module 5 notifications
# Firebase Cloud Messaging legacy HTTP API server key. Keep server-side only.
FCM_SERVER_KEY=

# SMTP HTML email reminders
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Module 8 JWT Authentication
# Generate a long random value and keep it server-side only.
SECRET_KEY=change-this-32-plus-character-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
