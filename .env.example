# Server
PORT=3000
APP_ORIGIN=http://localhost:3000
SESSION_SECRET=change-this-long-random-secret

# News providers
FREENEWSAPI_KEY=your_freenewsapi_key_here
NEWS_API_KEY=your_news_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here
MEDIASTACK_API_KEY=your_mediastack_api_key_here

# RSS sources do not usually need API keys.
# Leave empty to use the built-in REGIONAL_SOURCE_CATALOG (multi-region RSS across 9 regions).
# Comma-separated URLs override the catalog entirely — use sparingly.
RSS_FEEDS=

# Regional fetch tuning
RSS_FETCH_CONCURRENCY=8
RSS_FETCH_TIMEOUT_MS=8000
RSS_CACHE_TTL_MS=300000

# Event providers
# Get a key from https://developer.ticketmaster.com/products-and-docs/apis/discovery-api/v2/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
EVENT_COUNTRY_CODE=TR
EVENT_CITY=Istanbul
EVENT_SIZE=18

# AI provider
# Gemini is currently wired in server.js.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Finance providers
# Harem Altin / AltinAPI: Dolar, Euro, sterlin ve altin fiyatlari icin oncelikli kaynak.
# Harem web sayfasi Cloudflare ile korunabildigi icin en stabil yol API key kullanmaktir.
HAREM_ALTIN_API_KEY=
HAREM_ALTIN_API_BASE_URL=https://altinapi.com/api/v1
# ─ TCMB today.xml (döviz kurları): Herkese açık, API key gerekmez.
# ─ metals.live (XAU/USD, XAG/USD): Herkese açık, API key gerekmez.
# ─ CoinGecko public (kripto): API key olmadan çalışır, rate limit uygulanır.
#   Pro API key ile rate limit artar — isteğe bağlı.
COINGECKO_API_KEY=
# ─ TCMB EVDS: Politika faizi (TP.DF.D03.A) ve makro seri verileri için.
#   Key sunucu tarafında .env içinde tutulur. Frontend'e kesinlikle açılmaz.
#   https://evds2.tcmb.gov.tr/ adresinden ücretsiz kayıt ile alınabilir.
EVDS_API_KEY=
# Backward-compatible legacy name:
TCMB_EVDS_API_KEY=
# ─ BIST gerçek zamanlı veri: Lisanslı veri sağlayıcı sözleşmesi gerektirir.
#   Sağlayıcı seçildikten sonra key buraya eklenir. Sahte değer gösterilmez.
BIST_PROVIDER_API_KEY=
BIST_PROVIDER_BASE_URL=
# ─ KAP bildirimleri: Lisans/sözleşme gerektirir. Sahte veri gösterilmez.
KAP_API_ENABLED=false
KAP_API_KEY=
KAP_API_BASE_URL=

# Source Follow Center
# YouTube RSS mode does not require a key. If API fallback is added in production, keep the key server-side only.
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here
SOURCE_FETCH_TIMEOUT_MS=6500
SOURCE_CACHE_TTL_MINUTES=15

# Python FastAPI crawler backend
# Example: postgresql+asyncpg://postgres:postgres@localhost:5432/smart_newspaper
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smart_newspaper

# Celery / Redis queue
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# DEDUPLICATION
# MinHash + LSH runs in-process and in the daily Celery task. Install backend/requirements.txt.

# NewsAPI provider pacing
NEWSAPI_RATE_LIMIT_SECONDS=36

# Module 3 personal newspaper / recommendation cache
PERSONAL_FEED_CACHE_TTL_SECONDS=300

# Module 5 notifications
# Firebase Cloud Messaging legacy HTTP API server key. Keep server-side only.
FCM_SERVER_KEY=

# SMTP HTML email reminders
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Module 8 JWT Authentication
# Generate a long random value and keep it server-side only.
SECRET_KEY=change-this-32-plus-character-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Multilingual NLP / preprocessing
NLP_ENABLED=true
NLP_CONFIDENCE_THRESHOLD=0.85
NLP_MIN_TEXT_LENGTH=20
NLP_MAX_WORKERS=4
NLP_TIMEOUT_SECONDS=5
TRANSLATION_ENABLED=false
TRANSLATION_PROVIDER=none
TRANSLATION_TARGET_LANGS=tr,en
DEDUP_ENABLED=true
DEDUP_TITLE_SIMILARITY_THRESHOLD=0.86
DEDUP_ENTITY_OVERLAP_THRESHOLD=0.40
NEWSPAPER_FORMATTER_ENABLED=true

# LLM Categorizer / validation fallback
LLM_CATEGORIZER_ENABLED=true
LLM_PRIMARY_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MAX_CONTENT_CHARS=2000
LLM_MAX_PROMPT_TOKENS=3000
LLM_MAX_RETRIES=2
LLM_CACHE_TTL_SECONDS=86400
LLM_CACHE_MAX_SIZE=1000
LLM_BATCH_MAX_CONCURRENT=5
LLM_TIMEOUT_SECONDS=10
LLM_COST_TRACKING_ENABLED=true
LLM_DAILY_COST_LIMIT_USD=5.00
LLM_CATEGORY_CONFIDENCE_THRESHOLD=0.85


# Admin manual reclassification / feedback loop
ADMIN_JWT_SECRET=
ADMIN_TOKEN_EXPIRE_HOURS=8
ADMIN_BOOTSTRAP_PASSWORD=admin123
RECLASSIFICATION_ENABLED=true
RECLASSIFICATION_RETRAIN_THRESHOLD=100
RECLASSIFICATION_DAILY_RATE_THRESHOLD=30
RECLASSIFICATION_ACCURACY_THRESHOLD=0.80
RECLASSIFICATION_ACCURACY_DROP_TOLERANCE=0.02
RECLASSIFICATION_STORE_PATH=
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
ADMIN_RATE_LIMIT_PER_MINUTE=60
ADMIN_MAX_FAILED_LOGIN_ATTEMPTS=5
MLFLOW_TRACKING_URI=

# ================= Notification System =================
NOTIFICATIONS_ENABLED=true
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@smartnewspaper.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
NOTIFICATION_SCHEDULER_INTERVAL_MS=60000
NOTIFICATION_MAX_RETRY=3
NOTIFICATION_RETRY_DELAY_MINUTES=5
DEFAULT_TIMEZONE=Europe/Istanbul
DEMO_USER_EMAIL=demo@smartnewspaper.local

# Advanced search and trend scheduler
SEARCH_TREND_SCHEDULER_ENABLED=true
SEARCH_TREND_SCHEDULER_INTERVAL_MS=900000
SEARCH_MAX_QUERY_LENGTH=150
SEARCH_DEFAULT_LIMIT=20
SEARCH_RATE_LIMIT_PER_MINUTE=60

# Analytics and Smart Recommendation Module
ANALYTICS_ENABLED=true
RECOMMENDATION_SCHEDULER_ENABLED=true
RECOMMENDATION_SCHEDULER_INTERVAL_MS=1800000
ANALYTICS_MAX_READING_SECONDS=600
ANALYTICS_DEFAULT_ANONYMOUS_ID=anon_demo
RECOMMENDATION_DEFAULT_LIMIT=12
RECOMMENDATION_MAX_LIMIT=50

# Usage Reports / RBAC / Audit Log
REPORTS_ENABLED=true
REPORT_STORAGE_DIR=generated-reports
REPORT_SCHEDULER_INTERVAL_MS=60000
REPORT_DEFAULT_TIMEZONE=Europe/Istanbul
RBAC_ENABLED=true
AUDIT_LOG_ENABLED=true
SYSTEM_METRICS_ENABLED=true
SYSTEM_METRICS_INTERVAL_MS=60000
